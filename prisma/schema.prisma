generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlayingLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  JUNIOR
}

enum MembershipPlan {
  SOCIAL_MEMBER
  PLAYER_MEMBER
  PERFORMANCE_MEMBER
}

enum PreferredTime {
  EARLY_MORNING
  MORNING
  EVENING
  LATE_EVENING
}

enum ContactTopic {
  MEMBERSHIP
  COACHING
  EVENTS
  TRIAL_SESSION
  FEEDBACK
  OTHER
}

enum EventCategory {
  CLINICS
  SOCIAL
  TOURNAMENT
  JUNIOR
}

model User {
  id               String              @id @default(cuid())
  name             String?
  email            String              @unique
  emailVerified    DateTime?
  image            String?
  passwordHash     String?
  phone            String?
  playingLevel     PlayingLevel?
  preferredTime    PreferredTime?
  membershipPlan   MembershipPlan?
  membershipStatus String?
  membershipRenewal DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  accounts         Account[]
  sessions         Session[]
  registrations    EventRegistration[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ContactInquiry {
  id        String       @id @default(cuid())
  fullName  String
  email     String
  topic     ContactTopic
  message   String
  createdAt DateTime     @default(now())
}

model MembershipApplication {
  id             String         @id @default(cuid())
  fullName       String
  email          String
  phone          String
  playingLevel   PlayingLevel
  preferredPlan  MembershipPlan
  preferredTime  PreferredTime
  notes          String?
  createdAt      DateTime       @default(now())
}

model NewsletterSubscription {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String?
  playingLevel PlayingLevel?
  createdAt    DateTime     @default(now())
}

model Event {
  id              String            @id @default(cuid())
  slug            String            @unique
  title           String
  description     String?
  startsAt        DateTime
  durationMinutes Int
  category        EventCategory
  level           String
  feeINR          Int
  capacity        Int
  location        String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  registrations   EventRegistration[]
}

model EventRegistration {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}
