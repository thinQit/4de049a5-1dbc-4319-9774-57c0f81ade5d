generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipPlan {
  STARTER
  CLUB
  PERFORMANCE
}

enum PlayingLevel {
  BEGINNER
  LEVEL_30_35
  LEVEL_40
  LEVEL_45_PLUS
}

enum InquiryTopic {
  MEMBERSHIP
  EVENTS
  COACHING
  SPONSORSHIP
  FEEDBACK
  OTHER
}

enum EventType {
  TOURNAMENT
  CLINIC
  SOCIAL
  JUNIORS
}

enum RegistrationStatus {
  CONFIRMED
  WAITLISTED
  CANCELLED
}

model User {
  id            String              @id @default(cuid())
  name          String?
  email         String              @unique
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  registrations EventRegistration[]
  applications  MembershipApplication[]
}

model ContactInquiry {
  id        String      @id @default(cuid())
  fullName  String
  email     String
  topic     InquiryTopic
  message   String
  consent   Boolean
  createdAt DateTime    @default(now())

  @@index([createdAt])
  @@index([topic])
}

model MembershipApplication {
  id                 String         @id @default(cuid())
  fullName           String
  email              String
  phone              String
  membershipPlan     MembershipPlan
  playingLevel       PlayingLevel
  goals              String
  preferredStartDate DateTime?
  consent            Boolean
  userId             String?
  user               User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt          DateTime       @default(now())

  @@index([createdAt])
  @@index([membershipPlan])
  @@index([playingLevel])
  @@index([userId])
}

model NewsletterSubscriber {
  id          String   @id @default(cuid())
  email       String   @unique
  interests   String[]
  consent     Boolean
  subscribedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([subscribedAt])
}

model Event {
  id            String              @id @default(cuid())
  slug          String              @unique
  title         String
  description   String
  eventDate     DateTime
  timeLabel     String
  type          EventType
  level         String
  priceLabel    String
  capacity      Int
  location      String
  isPublished   Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  registrations EventRegistration[]

  @@index([eventDate])
  @@index([type])
  @@index([isPublished])
}

model EventRegistration {
  id         String             @id @default(cuid())
  eventId    String
  userId     String
  status     RegistrationStatus @default(CONFIRMED)
  partnerName String?
  notes      String?
  createdAt  DateTime           @default(now())

  event      Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId, createdAt])
  @@index([eventId, status])
}
